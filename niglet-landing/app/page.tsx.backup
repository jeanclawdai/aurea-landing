      </div>
      
      <div className="max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center relative z-10">
        {/* Left - Text */}
        <motion.div 
          initial={{ opacity: 0, x: -50 }}
          animate={{ opacity: 1, x: 0 }}
          transition={{ duration: 0.8 }}
        >
          {/* Rarity pill */}
          <div className="rarity-pill mb-4">
            <span className="hyper">Hyper Rare</span>
            <span className="divider">—</span>
            <span className="oneofone">1/1</span>
          </div>
          
          <h1 className="font-display text-5xl md:text-7xl text-silver-light mb-6">
              <ShinyText 
                text="✨ $Nigglet" 
                speed={1.5} 
                color="#9ca3af" 
                shineColor="#ffffff" 
                spread={120} 
                direction="left" 
              />
          </h1>
          
          <p className="text-xl text-silver mb-8 max-w-md">
            A shiny trench-born meme with collector-grade energy.
          </p>

          <div className="flex flex-wrap gap-4 mb-8">
            <a href="#buy" className="holo-button text-lg px-8 py-4">
              <span>Buy $NIGLET</span>
            </a>
            <a href="#lore" className="glass-panel px-8 py-4 text-silver hover:text-white transition-colors">
