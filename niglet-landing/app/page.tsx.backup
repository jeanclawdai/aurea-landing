'use client'

import { useState, useRef, useEffect } from 'react'
import { motion, useScroll, useTransform, AnimatePresence } from 'framer-motion'
import dynamic from 'next/dynamic'

// Dynamic imports for reactbits components
const ColorBends = dynamic(
  () => import('reactbits-installer/components/ColorBends').then(mod => mod.default),
  { ssr: false, loading: () => null }
)

// Custom ShinyText component
import ShinyText from '../components/ShinyText'

// ============ COMPONENTS ============

// Navigation
function Navbar() {
  const [isScrolled, setIsScrolled] = useState(false)

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 50)
    }
    window.addEventListener('scroll', handleScroll)
    return () => window.removeEventListener('scroll', handleScroll)
  }, [])

  return (
    <nav className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
      isScrolled ? 'glass-panel py-3' : 'py-5'
    }`}>
      <div className="max-w-6xl mx-auto px-6 flex items-center justify-between">
        {/* Left - Chart Link */}
        <a 
          href="#chart" 
          className="text-silver hover:text-holo-cyan transition-colors font-medium"
        >
          Chart
        </a>

        {/* Center - Logo */}
        <div className="font-display text-2xl tracking-wider text-silver-light">
          NIGLET
        </div>

        {/* Right - CTA */}
        <a 
          href="#buy"
          className="holo-button text-sm"
        >
          <span>Buy $NIGLET</span>
        </a>
      </div>
      
      {/* Holo border line */}
      <div className="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-holo-cyan/50 to-transparent" />
    </nav>
  )
}

