@import url('https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800;900&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --base: #060010;
  --base-dark: #0F172A;
  --base-darker: #111827;
  --silver-light: #EEF2F7;
  --silver: #D7DCE6;
  --silver-dark: #9CA3AF;
  --holo-cyan: #47E7FF;
  --holo-violet: #B06CFF;
  --holo-magenta: #FF5CC8;
  --holo-gold: #FFE07A;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  background-color: var(--base);
  color: var(--silver-light);
  font-family: 'Figtree', system-ui, sans-serif;
  overflow-x: hidden;
}

h2 {
  font-weight: 700;
}

/* Cosmic grain background */
.cosmic-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 0;
  background: 
    radial-gradient(ellipse at 20% 20%, rgba(71, 231, 255, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 80%, rgba(176, 108, 255, 0.03) 0%, transparent 50%),
    radial-gradient(ellipse at 50% 50%, rgba(255, 92, 200, 0.02) 0%, transparent 60%),
    var(--base);
}

.cosmic-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  opacity: 0.5;
}

/* Glass panel */
.glass-panel {
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(215, 220, 230, 0.15);
  border-radius: 12px;
}

/* Chrome border */
.chrome-border {
  position: relative;
  border: 1px solid rgba(215, 220, 230, 0.3);
  border-radius: 8px;
}

.chrome-border::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 8px;
  padding: 1px;
  background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0.2) 100%);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

/* Holo border */
.holo-border {
  position: relative;
}

.holo-border::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(135deg, var(--holo-cyan), var(--holo-violet), var(--holo-magenta), var(--holo-gold));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.6;
}

/* Holo button */
.holo-button {
  position: relative;
  background: linear-gradient(135deg, rgba(71, 231, 255, 0.1), rgba(176, 108, 255, 0.1));
  border: 1px solid rgba(215, 220, 230, 0.4);
  border-radius: 8px;
  padding: 12px 24px;
  color: var(--silver-light);
  font-weight: 600;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s ease;
}

.holo-button::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--holo-cyan), var(--holo-violet), var(--holo-magenta));
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 0;
}

.holo-button:hover::before {
  opacity: 0.15;
}

.holo-button:hover {
  border-color: var(--holo-cyan);
  box-shadow: 0 0 20px rgba(71, 231, 255, 0.3);
}

.holo-button span {
  position: relative;
  z-index: 1;
}

/* Sparkle effect */
.sparkle {
  position: absolute;
  width: 4px;
  height: 4px;
  background: white;
  border-radius: 50%;
  animation: sparkle 0.6s ease-out forwards;
}

@keyframes sparkle {
  0% { transform: scale(0); opacity: 1; }
  100% { transform: scale(2); opacity: 0; }
}

/* Shimmer sweep */
.shimmer-sweep {
  position: relative;
  overflow: hidden;
}

.shimmer-sweep::after {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  animation: shimmer-sweep 3s ease-in-out infinite;
}

@keyframes shimmer-sweep {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* Holo card */
.holo-card {
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.1s ease-out;
}

.holo-card-inner {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(71, 231, 255, 0.05), rgba(176, 108, 255, 0.05), rgba(255, 92, 200, 0.05));
  border: 2px solid rgba(215, 220, 230, 0.2);
}

.holo-card-shine {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, 
    transparent 0%, 
    rgba(71, 231, 255, 0.1) 25%, 
    rgba(176, 108, 255, 0.15) 50%, 
    rgba(255, 92, 200, 0.1) 75%, 
    transparent 100%);
  mix-blend-mode: color-dodge;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

/* Section chrome frame */
.section-frame {
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(215, 220, 230, 0.1);
  border-radius: 16px;
  padding: 3rem;
  position: relative;
}

.section-frame::before {
  content: '';
  position: absolute;
  top: 0;
  left: 20%;
  right: 20%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(215, 220, 230, 0.3), transparent);
}

/* FAQ accordion */
.faq-item {
  border-bottom: 1px solid rgba(215, 220, 230, 0.1);
}

.faq-question {
  cursor: pointer;
  padding: 1rem 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-weight: 500;
}

.faq-answer {
  overflow: hidden;
  max-height: 0;
  transition: max-height 0.3s ease-out;
}

.faq-answer.open {
  max-height: 200px;
}

/* Starfield particles */
.star {
  position: absolute;
  width: 2px;
  height: 2px;
  background: white;
  border-radius: 50%;
  animation: twinkle 3s ease-in-out infinite;
}

@keyframes twinkle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* Shiny text animation */
.shiny-text {
  color: #4f4f4f;
  background: linear-gradient(
    110deg,
    transparent 0%,
    transparent 35%,
    rgba(255, 255, 255, 0.8) 45%,
    rgba(255, 255, 255, 1) 50%,
    rgba(255, 255, 255, 0.8) 55%,
    transparent 65%,
    transparent 100%
  );
  background-size: 200% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  display: inline-block;
  font-weight: 800;
  letter-spacing: 0.02em;
  animation: shine 1.8s linear infinite;
}

@keyframes shine {
  0% {
    background-position: 100% 0;
  }
  100% {
    background-position: -100% 0;
  }
}

@keyframes shine {
  0% {
    background-position: 100%;
  }
  100% {
    background-position: -100%;
  }
}

/* Rarity pill */
.rarity-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 1rem;
  border-radius: 9999px;
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: linear-gradient(
    135deg,
    rgba(71, 231, 255, 0.15),
    rgba(176, 108, 255, 0.15),
    rgba(255, 92, 200, 0.15)
  );
  border: 1px solid rgba(255, 255, 255, 0.2);
  box-shadow: 
    0 4px 20px rgba(71, 231, 255, 0.2),
    0 2px 8px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  position: relative;
  overflow: hidden;
}

.rarity-pill::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  animation: pill-shine 3s ease-in-out infinite;
}

@keyframes pill-shine {
  0% { left: -100%; }
  100% { left: 100%; }
}

.rarity-pill .hyper {
  color: var(--holo-cyan);
  text-shadow: 0 0 10px rgba(71, 231, 255, 0.5);
}

.rarity-pill .divider {
  color: rgba(255, 255, 255, 0.3);
}

.rarity-pill .oneofone {
  color: var(--holo-magenta);
  text-shadow: 0 0 10px rgba(255, 92, 200, 0.5);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
